---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-serif-4/cyrillic-400.css';
import '@fontsource/source-serif-4/cyrillic-600.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
interface Props {
  title?: string;
  register?: 'editorial' | 'technical';
}
const { title = 'atassis', register = 'editorial' } = Astro.props;
const variant = register === 'technical' ? 'd' : 'a';
---

<!doctype html>
<html lang="en" data-variant={variant}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.dataset.theme = 'dark'; } catch (e) { /* ignore */ }
    </script>
    <ClientRouter />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar__inner">
        <a class="brand" href="/">Taimuraz&nbsp;Kaitmazov</a>
        <nav class="topnav">
          <a href="/">home</a>
          <a href="/work">work</a>
          <a href="/writing/why-this-site">writing</a>
          <a href="/verse">verse</a>
          <button class="theme-toggle" type="button" aria-label="Toggle dark theme (m)" aria-keyshortcuts="m"><span class="ico">&#9790;</span><kbd class="k">m</kbd></button>
        </nav>
      </div>
    </header>
    <slot />
    <footer
      style="max-width: var(--measure-prose); margin: 0 auto; padding: var(--rhythm) 1.5rem calc(var(--rhythm)*2); border-top: 1px solid var(--color-rule); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); text-align: center;"
    >
      <a href="/" style="color: var(--color-muted);">home</a> &middot;
      <a href="/work" style="color: var(--color-muted);">work</a> &middot;
      <a href="/writing/why-this-site" style="color: var(--color-muted);">writing</a> &middot;
      <a href="/verse" style="color: var(--color-muted);">verse</a> &middot;
      <a href="/lab" style="color: var(--color-muted);">lab</a>
    </footer>
    <script>
      function __syncTheme() {
        var d = document.documentElement.dataset.theme === 'dark';
        document.querySelectorAll('.theme-toggle').forEach(function (b) {
          var ico = b.querySelector('.ico');
          if (ico) ico.textContent = d ? '☀' : '☾';
          b.setAttribute('aria-pressed', String(d));
        });
      }
      function __toggleTheme() {
        var d = document.documentElement.dataset.theme !== 'dark';
        if (d) document.documentElement.dataset.theme = 'dark';
        else delete document.documentElement.dataset.theme;
        try { localStorage.setItem('theme', d ? 'dark' : 'light'); } catch (e) {}
        __syncTheme();
      }
      if (!window.__themeWired) {
        window.__themeWired = true;
        document.addEventListener('click', function (e) {
          if (e.target && e.target.closest && e.target.closest('.theme-toggle')) __toggleTheme();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key !== 'm') return;
          var t = e.target;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
          __toggleTheme();
        });
      }
      __syncTheme();
      document.addEventListener('astro:after-swap', function () {
        // View Transitions reset <html> to the new page's server attributes (no theme) — re-apply before paint
        try { if (localStorage.getItem('theme') === 'dark') document.documentElement.dataset.theme = 'dark'; } catch (e) {}
        __syncTheme();
      });
    </script>
  </body>
</html>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 40;
    background: color-mix(in srgb, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-rule);
  }
  .topbar__inner {
    max-width: 60rem; margin: 0 auto; padding: 0.7rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    font-family: var(--font-mono); font-size: var(--text-sm);
  }
  .brand { color: var(--color-ink); text-decoration: none; font-weight: 600; }
  .topnav { display: flex; align-items: center; gap: 1rem; }
  .topnav a { color: var(--color-muted); text-decoration: none; }
  .topnav a:hover { color: var(--color-accent); }
  .theme-toggle {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: none; border: 1px solid var(--color-rule); border-radius: 4px;
    cursor: pointer; color: var(--color-muted); padding: 0.18rem 0.4rem;
    font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1;
  }
  .theme-toggle:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .theme-toggle .ico { font-size: 1.05em; }
  .theme-toggle .k { border-color: currentColor; }
</style>
