---
// Smart anchor: external http(s) links open in a new tab with a ↗ marker;
// internal links (and mailto:) render as a plain same-tab anchor. One rule,
// applied everywhere, so link behavior is predictable across the whole site.
interface Props {
  href: string;
  class?: string;
}
const { href, class: cls } = Astro.props;
const external = /^https?:\/\//.test(href);
---
{external ? (
  <a href={href} class={cls} target="_blank" rel="noopener noreferrer"><slot /><span class="ext-mark" aria-hidden="true">&#8599;</span></a>
) : (
  <a href={href} class={cls}><slot /></a>
)}

<style>
  .ext-mark {
    font-size: 0.78em;
    line-height: 1;
    vertical-align: 0.18em;
    margin-left: 0.12em;
    opacity: 0.7;
  }
</style>
