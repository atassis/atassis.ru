---
import Base from '../layouts/Base.astro';
import VariantSwitcher from '../components/VariantSwitcher';
import Verify from '../components/Verify.astro';
import A from '../components/A.astro';

// [verify] only where a real receipt exists. No public proof → honest status tag, never a verify button.
const crowns = [
  {
    claim: 'Built a from-scratch on-device NPU inference engine (open kernels, Apache-2.0) — runs whole model graphs on the laptop NPU: a 16-model loader, 6 proven end-to-end. Showed by device trace it’s data-movement-bound (~93% of on-device time is overhead, not compute) and cut it there. When AMD’s toolchain broke under the load, I fixed its compiler, operators, driver, and LLVM backend rather than stop — 20+ fixes merged by AMD, one merged into upstream LLVM itself, 4 more in review.',
    explain: 'The engine is public (Apache-2.0) — and so are the PRs: public, third-party-accepted evidence of the work it required. Every fix exists because my own build hit it — the compiler (mlir-aie), the operators (IRON), the runtime (mlir-air), and the LLVM backend (llvm-aie).',
    proof: [
      ['xdna-engine (repo)', 'https://github.com/atassis/xdna-engine'],
      ['mlir-aie #3178', 'https://github.com/Xilinx/mlir-aie/pull/3178'],
      ['amd/IRON #124', 'https://github.com/amd/IRON/pull/124'],
      ['llvm-aie #1059', 'https://github.com/Xilinx/llvm-aie/pull/1059'],
    ],
    status: null,
    caseLink: '/work/npu-engine',
  },
  {
    claim: 'Fixes merged upstream in Zed and helm-diff; an open speculative-decoding PR to vLLM.',
    explain: 'Zed & helm-diff read “Merged”; the vLLM PR is open — third parties accepted (or are reviewing) the code, not me.',
    proof: [
      ['zed #13840', 'https://github.com/zed-industries/zed/pull/13840'],
      ['helm-diff #294', 'https://github.com/databus23/helm-diff/pull/294'],
      ['vllm #44698', 'https://github.com/vllm-project/vllm/pull/44698'],
    ],
    status: null,
  },
  {
    claim: 'Production AI for a top-3 B2B accounting-software publisher: a payroll-compliance agent, a self-hosted OCR→LLM extraction pipeline (chosen on a labeled gold-set), vLLM-on-H100.',
    explain: null,
    proof: [],
    status: 'private',
  },
];

const repos = [
  ['kde-mcp', 'https://github.com/atassis/kde-mcp', 'computer-use MCP server for the Linux desktop (KDE/Wayland) — accessibility-tree-first, not pixel-clicks.', '/work/kde-mcp'],
  ['tnl', 'https://github.com/atassis/tnl', 'self-hosted ngrok alternative: one-command reverse tunnels behind your own Caddy.'],
  ['evbridge', 'https://github.com/atassis/evbridge', 'evdev→Wayland input bridge for headless / nested compositors.'],
  ['run-script-webpack-plugin', 'https://github.com/atassis/run-script-webpack-plugin', 'in NestJS’ official HMR docs; ~600K npm downloads/mo.'],
  ['rethinkdb-ts', 'https://github.com/rethinkdb/rethinkdb-ts', 'top contributor (~63% of commits, 9+ merged PRs incl. releases).'],
];
---

<Base title="Taimuraz Kaitmazov — AI Platform & Systems Engineer">
  <VariantSwitcher client:load />

  <main class="wrap">
    <header class="lede">
      <h1>Taimuraz Kaitmazov</h1>
      <p class="tagline">
        I build deep, correct systems across unfamiliar stacks &mdash; AI platform, on-device NPU
        inference, backend, Linux internals.
      </p>
      <p class="muted lede-sub">
        I go deep in unfamiliar, hard systems most engineers won&rsquo;t touch &mdash; and land results
        their own experts merge: AMD took 20+ of my fixes into their NPU toolchain, one into LLVM
        itself. AI does a lot of the typing; the discipline that keeps it correct &mdash; benchmarks,
        gold-sets, byte-exact diffs &mdash; is how I stay right in a stack I didn&rsquo;t start in.
      </p>
    </header>

    <section class="grid">
      <h2 class="label">Lately</h2>
      <p class="hint">Claims with a public receipt open to it &mdash; click <span class="kbdish">&#9656; verify</span>, or press <kbd>v</kbd> for all.</p>
      {crowns.map((c) => (
        <div class="crown">
          <p class="crown__claim">{c.claim}</p>
          <div class="crown__verify">
            <Verify explain={c.explain} proof={c.proof} status={c.status} caseLink={c.caseLink} />
          </div>
        </div>
      ))}
    </section>

    <section class="grid">
      <h2 class="label">Open source</h2>
      {repos.map(([name, url, desc, caseLink]) => (
        <p class="repo">
          <A class="repo__name" href={url}>{name}</A>
          <span class="muted"> &mdash; {desc}</span>
          {caseLink && <span class="muted"> · <a href={caseLink}>read the case</a></span>}
        </p>
      ))}
    </section>

    <section class="lede">
      <h2 class="label">Contact</h2>
      <p>
        <a href="mailto:atassikay38@gmail.com">atassikay38@gmail.com</a>
        <span class="muted"> &middot; </span>
        <A href="https://github.com/atassis">github.com/atassis</A>
      </p>
      <p class="muted small">Remote-first &middot; open to relocation &middot; Moscow (UTC+3)</p>
    </section>
  </main>
</Base>


<style>
  .wrap {
    max-width: 60rem;
    margin: 0 auto;
    padding: calc(var(--rhythm) * 1.2) 1.5rem calc(var(--rhythm) * 3);
  }
  .lede { max-width: var(--measure-prose); }
  .muted { color: var(--color-muted); }
  .small { font-size: var(--text-sm); }

  h1 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-4xl);
    line-height: 1.08;
    margin: 0;
  }
  .tagline { font-size: var(--text-lg); margin: var(--rhythm) 0 0; }
  .lede-sub { margin: calc(var(--rhythm) * 0.5) 0 0; }

  section { margin-bottom: calc(var(--rhythm) * 2); }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: 1.5rem;
  }
  .label {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: calc(var(--rhythm) * 0.25);
    margin: 0 0 calc(var(--rhythm) * 0.5);
  }
  .hint {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: 0 0 var(--rhythm);
  }
  .kbdish { color: var(--color-accent); }

  .crown {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: 1.5rem;
    align-items: start;
    margin-bottom: var(--rhythm);
  }
  .crown__claim { grid-column: 1 / 9; margin: 0; text-wrap: pretty; }
  .crown__verify { grid-column: 9 / 13; }

  .repo { grid-column: span 6; margin: 0 0 calc(var(--rhythm) * 0.5); }
  .repo__name { font-family: var(--font-mono); font-size: var(--text-sm); }

  @media (max-width: 820px) {
    .crown { grid-template-columns: 1fr; }
    .crown__claim,
    .crown__verify { grid-column: 1 / -1; }
    .crown__verify { margin-top: calc(var(--rhythm) * 0.25); }
    .repo { grid-column: 1 / -1; }
  }
</style>
