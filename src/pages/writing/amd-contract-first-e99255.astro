---
import Base from '../../layouts/Base.astro';
import StatStrip from '../../components/StatStrip.astro';
import A from '../../components/A.astro';
import { Content } from '../../writing/amd-contract-first.md';
import heroSvg from '../../diagrams/collapse.svg?raw';

// StatStrip renders [label, value] with `value` as the big accent number.
const stats: [string, string][] = [
  ['the only capability hook', '__AIE_ARCH__'],
  ['near-duplicate backends', '3'],
  ['lines duplicated across them', '~97k'],
  ['SubtargetFeature flags', '0'],
  ['arch-gated call sites', '~450'],
  ['repos the contracts need', '2–3'],
];

// Sources — every figure is grepped from public repos; the reader can check each.
const sources: [string, string?][] = [
  ['llvm-aie (the AIE backend)', 'https://github.com/Xilinx/llvm-aie'],
  ['mlir-aie (the compiler)', 'https://github.com/Xilinx/mlir-aie'],
  ['amd/xdna-driver (the KMD)', 'https://github.com/amd/xdna-driver'],
  ['AMD Triton-XDNA (per-arch transform)', 'https://github.com/amd/Triton-XDNA'],
];
const priorArt: [string, string?][] = [
  ['HetGPU — portable GPU IR (arXiv 2506.15993)', 'https://arxiv.org/abs/2506.15993'],
  ['Kernel Contracts (arXiv 2604.22032)', 'https://arxiv.org/abs/2604.22032'],
];
---

<Base title="A contract-first view of the AMD NPU stack" noindex={true}>
  <main class="wrap">
    <p class="back"><a href="/writing/why-this-site">← writing</a></p>

    <header class="lede">
      <p class="kicker">atassis &middot; writing &middot; draft</p>
      <h1>A contract-first view of the AMD NPU stack</h1>
      <p class="dek">Why about ten repos move in lockstep, and what freezing three interfaces would change. An outside suggestion, not a verdict.</p>
    </header>

    <StatStrip stats={stats} />

    <figure class="fig">
      <div class="fig__heads">
        <span class="fig__head">Today — ten repos, in lockstep</span>
        <span class="fig__head fig__head--after">Freeze three contracts</span>
      </div>
      <div class="fig__svg" set:html={heroSvg} />
      <dl class="legend">
        <div class="legend__item"><dt>C1</dt><dd>the AIE ISA — a queryable capability set</dd></div>
        <div class="legend__item"><dt>C2</dt><dd>the binary + graph container, with a portable tier</dd></div>
        <div class="legend__item"><dt>C3</dt><dd>the dispatch + memory-topology ABI</dd></div>
      </dl>
      <figcaption>Ten repos, three survivors: each surviving boundary carries a frozen contract or a hard wall. The three contracts are the argument below.</figcaption>
    </figure>

    <div class="article">
      <div class="article__body amd-prose">
        <Content />
      </div>

      <aside class="ledger" aria-label="Sources">
        <div class="ledger__inner">
          <div class="ledger__label">sources</div>
          <p class="ledger__note">Every figure here is grepped from public AMD repos. Nothing is asserted you cannot check.</p>
          <ul class="ledger__list">
            {sources.map(([name, url]) => (
              <li>{url ? <A href={url}>{name}</A> : <span>{name}</span>}</li>
            ))}
          </ul>
          <div class="ledger__label ledger__label--sub">prior art</div>
          <ul class="ledger__list">
            {priorArt.map(([name, url]) => (
              <li>{url ? <A href={url}>{name}</A> : <span>{name}</span>}</li>
            ))}
          </ul>
          <div class="ledger__label ledger__label--sub">standing</div>
          <p class="ledger__note">I build on this stack from the outside, and I ship fixes into it: <A href="https://github.com/search?q=is%3Apr+author%3Aatassis+is%3Amerged&type=pullrequests">20+ merged PRs</A> across AMD / LLVM repos.</p>
          <p class="ledger__note ledger__disc">Not affiliated with AMD. An outside reading of a public stack.</p>
        </div>
      </aside>
    </div>

    <nav class="casenav">
      <a href="/writing/why-this-site">← writing</a>
      <a href="/work/npu-engine">the engine →</a>
    </nav>
  </main>
</Base>

<style>
  .wrap { max-width: 62rem; margin: 0 auto; padding: calc(var(--rhythm) * 1.2) 1.5rem calc(var(--rhythm) * 3); }
  .back { font-family: var(--font-mono); font-size: var(--text-xs); margin: 0 0 var(--rhythm); }

  .lede { max-width: var(--measure-prose); }
  .kicker {
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-accent); margin: 0;
  }
  .lede h1 {
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-3xl);
    line-height: 1.1; margin: calc(var(--rhythm) * 0.5) 0 0;
  }
  .dek {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-muted);
    margin: calc(var(--rhythm) * 0.5) 0 0; max-width: var(--measure-prose);
  }

  /* figures — break out to the full content width so diagram labels stay legible */
  .fig { margin: calc(var(--rhythm) * 1.5) 0; padding: 0; }
  /* before/after framing as HTML (styled + aligned, no in-SVG clipping) */
  .fig__heads {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    /* boxes sit 2.2% inset from the figure edges (D2 pad); match it so each
       label locks onto its box edge */
    padding: 0 2.2%;
    font-family: var(--font-mono); font-size: var(--text-xs);
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: calc(var(--rhythm) * 0.5);
  }
  .fig__head { color: var(--color-muted); }
  .fig__head--after { color: var(--color-accent); text-align: right; }
  .fig__svg { display: block; }
  .fig__svg :global(svg) { display: block; width: 100%; height: auto; }
  /* diagram labels in the site's mono voice; trim ~9% since mono is wider than
     the font D2 measured the boxes with (px is user-units, so this stays
     responsive) — keeps survivor text off the box borders */
  .fig__svg :global(text), .fig__svg :global(tspan) {
    font-family: var(--font-mono); font-size: 14.5px !important;
  }
  /* key defining C1 / C2 / C3, since the diagram precedes the argument */
  .legend {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0.35rem 1.75rem;
    margin: var(--rhythm) auto 0; max-width: var(--measure-prose);
    font-family: var(--font-mono); font-size: var(--text-xs);
  }
  .legend__item { display: flex; align-items: baseline; gap: 0.5rem; margin: 0; }
  .legend dt { color: var(--color-accent); font-weight: 600; }
  .legend dd { margin: 0; color: var(--color-muted); }
  .fig figcaption {
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted);
    margin-top: calc(var(--rhythm) * 0.6); text-align: center; text-wrap: pretty;
  }

  /* two-column body + sticky sources ledger (the npu-engine case layout) */
  .article { display: grid; grid-template-columns: minmax(0, 1fr) 15rem; column-gap: 2.5rem; align-items: start; }
  .article__body { min-width: 0; max-width: var(--measure-prose); }
  .ledger { position: sticky; top: calc(var(--rhythm) * 1.5); }
  .ledger__inner { border-left: 1px solid var(--color-rule); padding-left: 1.25rem; }
  .ledger__label {
    font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-accent); margin: 0 0 calc(var(--rhythm) * 0.5);
  }
  .ledger__label--sub { margin-top: var(--rhythm); }
  .ledger__note { font-size: var(--text-xs); color: var(--color-muted); line-height: calc(var(--rhythm) * 0.92); margin: 0 0 var(--rhythm); }
  .ledger__disc { margin-top: var(--rhythm); font-style: italic; }
  .ledger__list { list-style: none; margin: 0; padding: 0; font-family: var(--font-mono); font-size: var(--text-xs); line-height: calc(var(--rhythm) * 1.05); }
  .ledger__list li { margin: 0 0 calc(var(--rhythm) * 0.35); }

  .casenav { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: var(--text-xs); border-top: 1px solid var(--color-rule); padding-top: var(--rhythm); margin-top: calc(var(--rhythm) * 2); }

  /* ---- prose: the rendered markdown body ---- */
  .amd-prose { color: var(--color-ink); }
  .amd-prose :global(p) { margin: 0 0 var(--rhythm); text-wrap: pretty; }
  /* section headings use the site's label idiom: mono, uppercase, accent, ruled */
  .amd-prose :global(h2) {
    font-family: var(--font-mono); font-weight: 400; font-size: var(--text-sm);
    text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-accent);
    border-bottom: 1px solid var(--color-rule); padding-bottom: calc(var(--rhythm) * 0.25);
    margin: calc(var(--rhythm) * 2) 0 var(--rhythm);
  }
  .amd-prose :global(h3) {
    font-family: var(--font-sans); font-weight: 700; font-size: var(--text-lg);
    margin: calc(var(--rhythm) * 1.4) 0 calc(var(--rhythm) * 0.4);
  }
  .amd-prose :global(strong) { font-weight: 700; color: var(--color-ink); }
  .amd-prose :global(a) { color: var(--color-accent); text-underline-offset: 2px; }
  .amd-prose :global(ul), .amd-prose :global(ol) { margin: 0 0 var(--rhythm); padding-left: 1.4rem; }
  .amd-prose :global(li) { margin: 0 0 calc(var(--rhythm) * 0.35); text-wrap: pretty; }
  .amd-prose :global(li)::marker { color: var(--color-muted); }

  .amd-prose :global(code) {
    font-family: var(--font-mono); font-size: 0.86em;
    background: color-mix(in srgb, var(--color-muted) 12%, transparent);
    padding: 0.06em 0.34em; border-radius: 3px;
  }
  .amd-prose :global(pre) {
    font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.5;
    margin: 0 0 var(--rhythm); padding: var(--rhythm); overflow-x: auto;
    border: 1px solid var(--color-rule); border-radius: 6px;
    background: color-mix(in srgb, var(--color-muted) 7%, transparent);
  }
  .amd-prose :global(pre code) { background: none; padding: 0; font-size: inherit; }
  /* Astro/Shiki ships github-dark; override to the site palette (monochrome, both themes) */
  .amd-prose :global(pre.astro-code) {
    background: color-mix(in srgb, var(--color-muted) 8%, transparent) !important;
    color: var(--color-ink) !important;
  }
  .amd-prose :global(pre.astro-code span) { color: inherit !important; }

  .amd-prose :global(table) {
    width: 100%; border-collapse: collapse; margin: 0 0 var(--rhythm);
    font-size: var(--text-sm); display: block; overflow-x: auto;
  }
  .amd-prose :global(thead th) {
    font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase;
    letter-spacing: 0.04em; text-align: left; color: var(--color-muted); font-weight: 500;
    border-bottom: 1.5px solid var(--color-rule); padding: 0.5rem 0.7rem;
  }
  .amd-prose :global(tbody td) {
    padding: 0.5rem 0.7rem; border-bottom: 1px solid var(--color-rule);
    vertical-align: top; text-wrap: pretty;
  }
  .amd-prose :global(tbody tr:hover) { background: color-mix(in srgb, var(--color-accent) 5%, transparent); }

  .amd-prose :global(blockquote) { margin: 0 0 var(--rhythm); padding-left: 1rem; border-left: 2px solid var(--color-accent); color: var(--color-muted); }
  .amd-prose :global(hr) { border: 0; border-top: 1px solid var(--color-rule); margin: calc(var(--rhythm) * 2) 0; }
  .amd-prose :global(em) { color: var(--color-muted); }

  @media (max-width: 820px) {
    .article { grid-template-columns: 1fr; row-gap: calc(var(--rhythm) * 1.5); }
    .ledger { position: static; }
    .ledger__inner { border-left: 0; border-top: 1px solid var(--color-rule); padding-left: 0; padding-top: var(--rhythm); }
  }
</style>
