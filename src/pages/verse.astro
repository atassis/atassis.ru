---
import Base from '../layouts/Base.astro';
import VariantSwitcher from '../components/VariantSwitcher';

// verse is always serif, regardless of the page register
const serif = "'Source Serif 4', Georgia, 'Times New Roman', serif";
---

<Base title="Verse — atassis">
  <VariantSwitcher client:load />
  <main style="max-width: var(--measure-verse); margin: 0 auto; padding: calc(var(--rhythm)*1.2) 1.5rem calc(var(--rhythm)*3);">
    <p style="font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); margin: 0;">
      стихи · verse
    </p>
    <h1 style="font-family: var(--font-sans); font-weight: 700; font-size: var(--text-3xl); line-height: 1.1; margin: calc(var(--rhythm)*0.5) 0 calc(var(--rhythm)*1.5);">
      Verse
    </h1>

    <article style={`font-family: ${serif}; font-size: var(--text-lg); line-height: var(--rhythm); hanging-punctuation: first;`}>
      <p style="margin: 0;">
        Люблю грозу в начале мая,<br />
        Когда весенний, первый гром,<br />
        как бы резвяся и играя,<br />
        Грохочет в небе голубом.
      </p>
    </article>

    <p style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); margin: calc(var(--rhythm)*1.5) 0 0; border-top: 1px solid var(--color-rule); padding-top: var(--rhythm);">
      placeholder — public-domain classic (Ф. Тютчев). Replace with your own strophe.
    </p>
  </main>
</Base>
